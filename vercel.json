{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    {
      "src": "/index.html",
      "headers": { "cache-control": "no-cache, no-store, must-revalidate" },
      "dest": "/index.html"
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
